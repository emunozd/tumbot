# ── Required ──────────────────────────────────────────────────────────────
FRED_API_KEY=your_fred_key_here          # free at fred.stlouisfed.org
TELEGRAM_BOT_TOKEN=123456789:AABBCCDDEEFFaabbccddeeff
TELEGRAM_LINK_SECRET=una-frase-secreta-que-solo-tu-sabes

# ── LLM — pick one backend ────────────────────────────────────────────────

# Option A: Claude (Anthropic)
LLM_BACKEND=anthropic
ANTHROPIC_API_KEY=sk-ant-your-key-here
LLM_MODEL=claude-sonnet-4-20250514

# Option B: Local OpenAI-compatible server (LM Studio, vLLM, custom, etc.)
# LLM_BACKEND=openai
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=none           # set to whatever your local server expects
# LLM_MODEL=llama3.2

# Option C: Groq (fast, generous free tier)
# LLM_BACKEND=openai
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_API_KEY=gsk_your_key_here
# LLM_MODEL=llama-3.3-70b-versatile

# ── Optional: real-time news feed ─────────────────────────────────────────
# FINNHUB_API_KEY=your_finnhub_key_here  # free at finnhub.io

# ── Optional: live trading on Polymarket ──────────────────────────────────
# POLY_PRIVATE_KEY=0x_your_polygon_wallet_private_key
# POLY_FUNDER_ADDRESS=0x_your_wallet_address_holding_usdc

# ── Optional: tune thresholds ─────────────────────────────────────────────
# MHS_MIN_DAILY=75        # minimum Market Heat Score to enter (0-100)
# EDGE_MIN=0.08           # minimum edge over market price (0.0-1.0)
# STOP_LOSS_PCT=0.35      # max loss per position as fraction of entry price
# TAKE_PROFIT_PCT=0.50    # profit target as fraction of entry price
# KELLY_FRACTION=0.25     # Kelly multiplier (0.25 = quarter-Kelly)
# CAPITAL_INITIAL=500.0   # starting USDC capital for paper trading
# BOT_DB=bot.db           # SQLite database file path